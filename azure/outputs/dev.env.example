# Astrolift Azure Terraform outputs — dev environment (example/template)
#
# Generated by run.sh after a successful apply. Consumed by:
#   - helm/astrolift values.azure.yaml templating
#   - cluster registration via `astro cluster register --plugin azure ...`

# Subscription + region
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_LOCATION=westus2
ENVIRONMENT=dev

# Resource group
RESOURCE_GROUP=dev-astrolift-rg

# Networking
VNET_NAME=dev-astrolift-vnet
AKS_SUBNET_NAME=dev-astrolift-aks
PE_SUBNET_NAME=dev-astrolift-pe

# Cluster
AKS_CLUSTER_NAME=dev-astrolift
AKS_OIDC_ISSUER_URL=https://oidc.prod-aks.azure.com/...
AKS_KUBELET_IDENTITY=

# Control-plane datastores
DATABASE_URL=postgres://USER:PASSWORD@<postgres-flex-fqdn>:5432/astrolift
DATABASE_HOST=
REDIS_URL=rediss://<redis-fqdn>:6380

# Object storage
STORAGE_ACCOUNT=devastrolift
STORAGE_CONTAINER=files

# Container registry
ACR_NAME=devastrolift
ACR_LOGIN_SERVER=devastrolift.azurecr.io

# Secrets
KEY_VAULT_NAME=dev-astrolift-kv
KEY_VAULT_SECRET_PREFIX=astrolift

# Workload Identity (drivers create federated credentials under this prefix)
UAMI_PREFIX=astrolift

# Observability (populated when toggles enable the relevant modules)
LOG_ANALYTICS_WORKSPACE_ID=
LOG_ANALYTICS_WORKSPACE_NAME=
MANAGED_PROM_WORKSPACE=
MANAGED_GRAFANA_ENDPOINT=
APPLICATION_INSIGHTS_ID=

# Backup (populated when enable_velero / enable_azure_backup_vault = true)
VELERO_STORAGE_ACCOUNT=
VELERO_CONTAINER=velero
RECOVERY_VAULT_NAME=

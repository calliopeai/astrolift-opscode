# Astrolift — Azure dev environment
#
# Copy this file to terraform.tfvars and fill in your values.
# `location` and `base_domain` are required (no defaults).

location    = "westus2"
base_domain = "dev.example.com"   # YOU bring this — must be an Azure DNS zone you own (or have NS-delegated)

# Runtime toggles (defaults: Container Apps on, AKS off in dev — flip if you want AKS only)
# enable_container_apps = true
# enable_aks            = false

# Observability + backup (dev=light)
# enable_fluent_bit            = true
# enable_managed_prom_grafana  = false
# enable_otel_azuremonitor     = true
# enable_workload_identity     = true
# enable_velero                = false
# enable_postgres_geo_backup   = false
# enable_blob_lifecycle        = false
# enable_azure_backup_vault    = false

# Astrolift AWS Terraform outputs — dev environment (example/template)
#
# Generated by run.sh after a successful apply. Consumed by:
#   - helm/astrolift values templating (DATABASE_URL, REDIS_URL, S3 bucket ARN, IRSA SA annotations)
#   - cold-boot.sh health checks
#   - downstream CI deploys
#
# This .example file is committed; the real dev.env is gitignored after generation.

# Region + identity
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=000000000000
ENVIRONMENT=dev

# Networking
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
PRIVATE_SUBNET_IDS=subnet-aaa,subnet-bbb,subnet-ccc
PUBLIC_SUBNET_IDS=subnet-ddd,subnet-eee,subnet-fff

# Cluster
EKS_CLUSTER_NAME=dev-astrolift
EKS_CLUSTER_ENDPOINT=https://XXXXXX.gr7.us-west-2.eks.amazonaws.com
EKS_CLUSTER_CA=
EKS_OIDC_PROVIDER_ARN=arn:aws:iam::000000000000:oidc-provider/oidc.eks.us-west-2.amazonaws.com/id/XXXXXX

# Control-plane datastores
DATABASE_URL=postgres://USER:PASSWORD@dev-astrolift-db.XXXXXX.us-west-2.rds.amazonaws.com:5432/astrolift
REDIS_URL=redis://dev-astrolift-redis.XXXXXX.cache.amazonaws.com:6379

# Object storage
S3_ARTIFACTS_BUCKET=dev-astrolift-files
S3_ARTIFACTS_BUCKET_ARN=arn:aws:s3:::dev-astrolift-files

# Container registry
ECR_REGISTRY=000000000000.dkr.ecr.us-west-2.amazonaws.com
ECR_BASE_REPO=000000000000.dkr.ecr.us-west-2.amazonaws.com/astrolift

# Secrets
SECRETS_MANAGER_PREFIX=/astrolift/dev
DB_CREDENTIALS_ARN=arn:aws:secretsmanager:us-west-2:000000000000:secret:dev-astrolift-db-credentials-XXXXXX

# IRSA paths (drivers create roles under this path)
IRSA_ROLE_PATH=/astrolift/

# Observability (populated when toggles enable the relevant modules)
AMP_WORKSPACE_ID=
AMP_QUERY_ENDPOINT=
AMG_WORKSPACE_ENDPOINT=
OPENSEARCH_ENDPOINT=
CLOUDWATCH_LOG_GROUP=/aws/eks/dev-astrolift

# Backup (populated when enable_aws_backup = true / enable_velero = true)
AWS_BACKUP_VAULT_ARN=
VELERO_BACKUP_BUCKET=

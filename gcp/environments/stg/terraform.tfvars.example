# Astrolift — GCP stg environment
#
# Copy this file to terraform.tfvars and fill in your values.
# `region`, `project_id`, and `base_domain` are required (no defaults).

region      = "us-west1"
project_id  = "my-gcp-project"
base_domain = "stg.example.com"   # YOU bring this — must be a Cloud DNS zone you own (or have NS-delegated)

# Runtime toggles (defaults: Cloud Run on, GKE off — flip if you want GKE only)
# enable_cloud_run = true
# enable_gke       = false

# Observability + backup (stg=most)
# enable_fluent_bit       = true
# enable_managed_prom     = false
# enable_otel_cloudtrace  = true
# enable_velero           = true
# enable_gcs_lifecycle    = true

# Cloud SQL (stg-tier defaults)
# db_tier                  = "db-custom-2-7680"
# db_availability_type     = "REGIONAL"
# db_disk_size             = 100
# db_backup_retention_days = 14
# db_read_replica_count    = 0

# Memorystore (stg-tier defaults)
# redis_memory_size_gb = 4
# redis_tier           = "STANDARD_HA"

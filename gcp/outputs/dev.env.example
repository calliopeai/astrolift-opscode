# Astrolift GCP Terraform outputs — dev environment (example/template)
#
# Generated by run.sh after a successful apply. Consumed by:
#   - helm/astrolift values.gcp.yaml templating
#   - cluster registration via `astro cluster register --plugin gcp ...`
#
# This .example file is committed; the real dev.env is gitignored.

# Project + region
GCP_PROJECT_ID=astrolift-dev
GCP_REGION=us-west1
ENVIRONMENT=dev

# Networking
VPC_NAME=dev-astrolift
PRIVATE_SUBNET_NAME=dev-astrolift-private
PODS_SECONDARY_RANGE=dev-astrolift-pods
SERVICES_SECONDARY_RANGE=dev-astrolift-services

# Cluster
GKE_CLUSTER_NAME=dev-astrolift
GKE_CLUSTER_LOCATION=us-west1
GKE_ENDPOINT=
WORKLOAD_IDENTITY_POOL=astrolift-dev.svc.id.goog

# Control-plane datastores
DATABASE_URL=postgres://USER:PASSWORD@<cloudsql-private-ip>:5432/astrolift
DATABASE_INSTANCE_CONNECTION=astrolift-dev:us-west1:dev-astrolift-postgres
REDIS_URL=redis://<memorystore-ip>:6379

# Object storage
GCS_ARTIFACTS_BUCKET=dev-astrolift-files

# Container registry
ARTIFACT_REGISTRY=us-west1-docker.pkg.dev/astrolift-dev/astrolift
ARTIFACT_REGISTRY_REPO=us-west1-docker.pkg.dev/astrolift-dev/astrolift

# Secrets
SECRET_MANAGER_PREFIX=astrolift

# Workload Identity (drivers create GSA bindings under this prefix)
WI_GSA_PREFIX=astrolift

# Observability (populated when toggles enable the relevant modules)
MANAGED_PROM_WORKSPACE=
CLOUD_LOGGING_LOG_ROUTER=
CLOUD_TRACE_PROJECT=

# Backup (populated when enable_velero / enable_cloudsql_pitr = true)
VELERO_BACKUP_BUCKET=
CLOUDSQL_BACKUP_RETENTION_DAYS=
